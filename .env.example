# TokenWise Configuration
# Copy this file to .env and adjust values as needed.

# Default model for token counting and cost estimation
TOKENWISE_DEFAULT_MODEL=gpt-4

# Logging level (DEBUG, INFO, WARNING, ERROR)
TOKENWISE_LOG_LEVEL=INFO

# Custom cost multiplier (e.g., 1.1 to add 10% buffer)
TOKENWISE_COST_MULTIPLIER=1.0
